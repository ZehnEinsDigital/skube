# Skube plugin configuration. NORMALLY YOU DON'T EDIT THIS FILE — run /skube:connect in
# Claude Code instead; it writes ~/.skube/.env for you. This template is for advanced/CLI use.
# The ONLY secret is your Skube API key — NEVER put Amazon (AMAZON_SP_*) or Anthropic/Claude
# keys here; those live in the Skube cloud and your own Claude plan respectively.

# Your Skube API key — create it on the Connect page of the Skube web app (/connect).
# Starts with lk_live_. Shown only once at creation.
SKUBE_API_KEY=lk_live_xxxxxxxxxxxxxxxxxxxx

# Skube cloud API base URL.
# Local test run of the stack: use http://localhost:8000
SKUBE_API_URL=https://skube-api-production.up.railway.app

# OPTIONAL — leave this UNSET for normal use. The plugin auto-provisions the engine
# snapshot from the Skube cloud into an EPHEMERAL per-session dir
# (~/.skube/.sessions/skube-run-*/engine — shredded when the session ends; there is no
# durable ~/.skube/engine). Only set this to override with your own WRITABLE engine
# copy (dev): SKUBE_ENGINE_DIR=/Users/you/skube-engine
# SKUBE_ENGINE_DIR=

# The brain bundle is written to the same ephemeral, per-session dir under
# ~/.skube/.sessions/skube-run-*/ (leased for 24h, refreshed while in use, reaped after
# expiry) — never a durable copy. There is no env var to configure this location.
